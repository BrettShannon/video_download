import subprocess
import os
from pathlib import Path

# --- 1. 基础配置（确定的绝对路径） ---
# 使用 r"" 避免那个讨厌的 Unicode 路径报错
YT_DLP = r"C:\Users\xzz\AppData\Local\Python\pythoncore-3.14-64\Scripts\yt-dlp.exe"
FFMPEG = r"D:\work_app\ffmpeg\ffmpeg-8.0.1-essentials_build\bin\ffmpeg.exe"
SAVE_DIR = Path(r"C:\Users\xzz\video_download")

def download_video_smart(url):
    # 确保保存目录存在
    SAVE_DIR.mkdir(exist_ok=True)
    
    # 定义临时文件名和最终文件名
    v_temp = SAVE_DIR / "temp_video.mp4"
    a_temp = SAVE_DIR / "temp_audio.webm"
    final_output = SAVE_DIR / "Downloaded_Video.mp4"

    print(f"🎬 准备下载任务...")

    try:
        # --- 2. 下载视频流 (bv = best video) ---
        print("📥 正在下载最佳画质视频（无声）...")
        subprocess.run([YT_DLP, "-f", "bv", "-o", str(v_temp), url], check=True)

        # --- 3. 下载音频流 (ba = best audio) ---
        print("📥 正在下载最佳音质音频...")
        subprocess.run([YT_DLP, "-f", "ba", "-o", str(a_temp), url], check=True)

        # --- 4. 使用 FFmpeg 合并 ---
        print("🔗 正在极速合并音视频...")
        # -c:v copy 表示直接复制视频，不重编码，速度极快
        # -y 表示如果文件已存在则覆盖
        cmd = [
            FFMPEG, "-i", str(v_temp), "-i", str(a_temp),
            "-c:v", "copy", "-c:a", "aac", "-y", str(final_output)
        ]
        subprocess.run(cmd, check=True)

        # --- 5. 过河拆桥（清理临时文件） ---
        v_temp.unlink(missing_ok=True)
        a_temp.unlink(missing_ok=True)
        print(f"✅ 大功告成！最终文件：{final_output}")
        
        # 自动打开文件夹
        os.startfile(SAVE_DIR)

    except Exception as e:
        print(f"❌ 出错了: {e}")

# --- 运行处 ---
if __name__ == "__main__":
    video_url = "https://www.youtube.com/watch?v=W9OGD_egM_Q"
